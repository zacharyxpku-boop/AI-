# ============================================================
# wenai environment checklist
# ============================================================
# Copy to .env.local for local development.
# Configure the same keys in Vercel Project Settings for deploys.

# ------------------------------------------------------------
# Required in production
# ------------------------------------------------------------

# App URL used by server-side pages and share/report links.
NEXT_PUBLIC_APP_URL=https://your-wenai-subsite.example.com

# AI chat provider.
# Supported by current adapters: DashScope compatible endpoint, DeepSeek compatible endpoint,
# OpenAI-compatible endpoint, or another OpenAI-compatible gateway.
AI_API_KEY=your_ai_api_key
AI_MODEL=qwen-plus
AI_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Auth and admin.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
PASSWORD_SALT=your_password_salt
ADMIN_KEY=your_admin_key_at_least_16_chars

# ------------------------------------------------------------
# Recommended for commercial POC
# ------------------------------------------------------------

# Redis persistence and rate limiting. Without Redis, some local/dev fallback paths work,
# but serverless deploys should use Redis for stable inquiries, share links, and limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email provider for digests or customer notifications when enabled.
RESEND_API_KEY=
SENDGRID_API_KEY=
MAIL_FROM=

# ------------------------------------------------------------
# Optional media providers
# ------------------------------------------------------------

# HappyHorse / Leone Cloud gateway for image and video modules.
HAPPYHORSE_API_KEY=
HAPPYHORSE_BASE_URL=https://mm-internal-cn.leonecloud.com

# DashScope Wanx image model.
WANX_MODEL=wanx2.1-t2i-turbo
WANX_DISABLED=0

# Optional future providers.
FAL_KEY=
REPLICATE_API_TOKEN=

# Gemini video teardown.
GEMINI_API_KEY=
GEMINI_BASE_URL=

# ------------------------------------------------------------
# Optional commercial and ops hooks
# ------------------------------------------------------------

# This subsite can keep payment and formal contracts on your main independent site.
# Enable Stripe only if you intentionally bring checkout back into this repo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Error monitoring.
SENTRY_DSN=

# External CRM sync. Leave empty to keep CRM export-only mode.
# Supported provider values: generic, hubspot, feishu.
EXTERNAL_CRM_PROVIDER=generic
EXTERNAL_CRM_WEBHOOK_URL=
EXTERNAL_CRM_TOKEN=

# Invite roster override as JSON.
# Example:
# INVITE_ROSTER={"demo":{"name":"Demo Team","expiresAt":"2026-12-31","tier":"team"}}
INVITE_ROSTER=
